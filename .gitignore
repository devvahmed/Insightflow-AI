# Gitignore for InsightFlow AI (Root Scope)

# =====================
# SENSITIVE FILES - NEVER PUSH THESE
# =====================
**/.env
**/serviceAccount.json
InsightFlow-backend/users.json

# =====================
# Python caches & build artifacts
# =====================
**/__pycache__/
**/*.py[cod]
**/*$py.class
.venv/
venv/
ENV/

# =====================
# Backend dynamic generated assets and logs
# =====================
InsightFlow-backend/generated_images/
InsightFlow-backend/traces/
InsightFlow-backend/uploads/*.mp4
InsightFlow-backend/uploads/ad_image_*.png
InsightFlow-backend/uploads/ad_thumb_*.png
InsightFlow-backend/uploads/vid_frame_*.png

# =====================
# Frontend dependencies and bundler caches
# =====================
**/node_modules/
InsightFlow-frontend/.expo/
InsightFlow-frontend/dist/
InsightFlow-frontend/web-build/
InsightFlow-frontend/expo-env.d.ts

# =====================
# IDE settings and system files
# =====================
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db

# Startup script
START_APP.bat
